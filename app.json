{
  "expo": {
    "name": "propertyloop-mobile",
    "slug": "propertyloop-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "propertyloopmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "url": "https://u.expo.dev/9f9d95ab-7568-41be-ad3a-101f1ca02a0b"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "ng.propertyloop.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 3,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-mark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/splash-mark.png",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PropertyLoop to use Face ID to protect permanent account actions."
        }
      ],
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "PropertyLoop needs access to your photos so you can upload listing images, a profile picture, verification documents, proof of completed work, and photo attachments in chat.",
          "cameraPermission": "PropertyLoop needs access to your camera so you can take a verification selfie, photograph completed jobs, and capture photos for your listings and messages."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f9d95ab-7568-41be-ad3a-101f1ca02a0b"
      }
    },
    "owner": "techprooo"
  }
}
